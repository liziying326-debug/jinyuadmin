    "langData": {
      "en": {
        "name": "Exhibition Display",
        "desc": "Trade shows, exhibitions, and corporate events demand portable, visually impactful display systems. Our display stands and print media combine ease of transport with professional presentation quality for global event professionals."
      },
      "zh": {
        "name": "展览展示",
        "desc": "贸易展会、展览和企业活动需要便携、视觉冲击力强的展示系统。我们的展示架和印刷介质结合了便于运输和专业展示品质的优点，为全球活动专业人士服务。"
      },
      "vi": {
        "name": "Trưng Bày Triển Lãm",
        "desc": "Các hội chợ thương mại, triển lãm và sự kiện doanh nghiệp đòi hỏi các hệ thống trưng bày di động, có tác động hình ảnh mạnh. Giá trưng bày và chất liệu in của chúng tôi kết hợp tính dễ vận chuyển với chất lượng trình bày chuyên nghiệp cho các chuyên gia sự kiện toàn cầu."
      },
      "ph": {
        "name": "Exhibition Display",
        "desc": "Ang trade shows, exhibitions, at corporate events ay nangangailangan ng portable, visually impactful display systems. Ang aming display stands at print media ay nagbibigay ng kadalian ng transport kasama ng professional presentation quality."
      }
